<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- El tema visible se maneja desde Compose (BaropodTheme).
         Aquí solo declaramos un tema base sin ActionBar para que el
         Activity arranque sin barra y no fuerce un color de fondo.

         La variante night se define en res/values-night/themes.xml. -->
    <style name="Theme.Baropod" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
